{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT \n                id,\n                project_id,\n                title,\n                description,\n                status AS \"status: TaskStatus\",\n                priority AS \"priority: TaskPriority\",\n                due_date,\n                created_at,\n                updated_at\n            FROM tasks\n            WHERE id = $1\n            AND project_id IN\n                (SELECT id FROM projects where user_id = $2)\n        ",
