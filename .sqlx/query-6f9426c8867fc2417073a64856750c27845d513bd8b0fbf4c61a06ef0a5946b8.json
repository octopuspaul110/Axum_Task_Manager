{
  "db_name": "PostgreSQL",
  "query": "\n            UPDATE tasks\n            SET\n                title = $1,\n                description = $2,\n                status = $3,\n                priority = $4,\n                due_date = $5,\n                updated_at = NOW()\n            WHERE id = $6\n                AND project_id IN (\n                    SELECT id FROM projects WHERE user_id = $7\n                )\n            RETURNING\n                id,\n                project_id,\n                title,\n                description,\n                status      AS \"status: TaskStatus\",\n                priority    AS \"priority: TaskPriority\",\n                due_date,\n                created_at,\n                updated_at\n        ",
